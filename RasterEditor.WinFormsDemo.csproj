<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <RootNamespace>RasterEditor.WinFormsDemo</RootNamespace>
    <AssemblyName>RasterEditor.WinFormsDemo</AssemblyName>
    <Product>RasterEditor WinForms Demo</Product>
    <Description>Учебный растровый редактор на C# WinForms: слои, 13 режимов наложения, фильтры, undo/redo.</Description>
    <Version>1.0.0</Version>
    <Authors>H1k4n</Authors>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryType>git</RepositoryType>
    <RepositoryUrl>https://github.com/H1k4n/RasterEditor.WinFormsDemo</RepositoryUrl>
    <StartupObject>RasterEditor.WinFormsDemo.Program</StartupObject>
  </PropertyGroup>

  <ItemGroup>
    <None Include="Palettes\**\*.json" CopyToOutputDirectory="PreserveNewest" LinkBase="Palettes" />
  </ItemGroup>
</Project>
